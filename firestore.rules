rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザーは自分のデータのみ読み書き可能
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // その他はすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
